# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── LLM (hybrid: Claude → Groq → Gemini) ──────────────────────────────────
# Primary — Claude Sonnet 4.6 + Haiku 4.5 (architecture-spec compliant)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Fallback — get free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Final fallback — get free key at https://aistudio.google.com
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Database ───────────────────────────────────────────────────────────────
# SQLite for local dev
DATABASE_URL=sqlite+aiosqlite:///./demo.db
# Railway Postgres (auto-injected when you link the Postgres add-on):
# DATABASE_URL=postgresql://user:pass@host/db  ← code auto-adds +asyncpg

# ── Demo site ──────────────────────────────────────────────────────────────
BASE_URL=https://lamaqrait.github.io/rait-qa-demo

# ── JWT Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-replace-with-openssl-rand-hex-32

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=LamaqRAIT
GITHUB_REPO_NAME=rait-qa-demo
GITHUB_WEBHOOK_SECRET=

# ── Langfuse ───────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# IMPORTANT: use your region URL here (US or EU):
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Slack (optional — creates real alerts) ────────────────────────────────
# How to get: api.slack.com/apps → Create → From scratch → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Jira (optional — uses persisted mock if not set) ─────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=RAIT

# ── Hosting ────────────────────────────────────────────────────────────────
AGENT_UI_URL=https://your-agent-ui.up.railway.app
BACKEND_URL=https://your-backend.up.railway.app
