<mxfile host="app.diagrams.net" version="21.0.0" pages="2">
  <diagram name="RAIT QA — Pipeline Architecture" id="rait-qa-arch">
    <mxGraphModel dx="1051" dy="724" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1680" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;b style=&quot;font-size:20px;&quot;&gt;RAIT QA — Pipeline Architecture&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#555;&quot;&gt;Orchestrator dispatches 7 pipeline nodes · each has bounded scope, own tool, own fallback, own metric · shared state in PostgreSQL · SSE live-stream to Agent UI&lt;/span&gt;" vertex="1"><mxGeometry height="60" width="2120" x="40" y="20" as="geometry" /></mxCell>
        <!-- LEGEND -->
        <mxCell id="leg-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;verticalAlign=top;fontSize=10;" value="&lt;b&gt;Legend&lt;/b&gt;" vertex="1"><mxGeometry height="145" width="340" x="1820" y="100" as="geometry" /></mxCell>
        <mxCell id="leg-orch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1E3A8A;fontStyle=1;fontSize=10;fontColor=#FFFFFF;" value="FastAPI Orchestrator (entry point)" vertex="1"><mxGeometry height="22" width="310" x="1835" y="125" as="geometry" /></mxCell>
        <mxCell id="leg-node" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;" value="Pipeline node (internal)" vertex="1"><mxGeometry height="22" width="310" x="1835" y="153" as="geometry" /></mxCell>
        <mxCell id="leg-infra" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="Infrastructure / data store" vertex="1"><mxGeometry height="22" width="310" x="1835" y="181" as="geometry" /></mxCell>
        <mxCell id="leg-ext" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="External service / human surface" vertex="1"><mxGeometry height="22" width="310" x="1835" y="209" as="geometry" /></mxCell>
        <!-- HUMAN-FACING ZONE -->
        <mxCell id="human-zone" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1;fontSize=11;" value="&lt;b&gt;Human-facing surface&lt;/b&gt; — only the Orchestrator API and Agent UI are visible to users; pipeline nodes are internal" vertex="1"><mxGeometry height="150" width="1740" x="40" y="100" as="geometry" /></mxCell>
        <mxCell id="eng" parent="1" style="shape=actor;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#333;fontSize=11;" value="&lt;b&gt;Developer&lt;/b&gt;" vertex="1"><mxGeometry height="70" width="55" x="70" y="133" as="geometry" /></mxCell>
        <mxCell id="qa-eng" parent="1" style="shape=actor;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#333;fontSize=11;" value="&lt;b&gt;QA Engineer&lt;/b&gt;" vertex="1"><mxGeometry height="70" width="55" x="165" y="133" as="geometry" /></mxCell>
        <mxCell id="qa-mgr" parent="1" style="shape=actor;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#333;fontSize=11;" value="&lt;b&gt;QA Manager&lt;/b&gt;" vertex="1"><mxGeometry height="70" width="55" x="260" y="133" as="geometry" /></mxCell>
        <mxCell id="agent-ui" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="&lt;b&gt;Agent UI (Next.js 15)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;NodeGraph · RunList · ApprovalQueue · MetricsPanel · RunReportDrawer · SSE consumer&lt;/span&gt;" vertex="1"><mxGeometry height="60" width="265" x="350" y="140" as="geometry" /></mxCell>
        <mxCell id="gh-pr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="&lt;b&gt;GitHub PR&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;branch: qa-agent/auto-heal · selector patch diff&lt;/span&gt;" vertex="1"><mxGeometry height="60" width="195" x="655" y="140" as="geometry" /></mxCell>
        <mxCell id="slack-out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="&lt;b&gt;Slack Alerts&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;#qa-alerts · PR opened · bug filed · HITL required · circuit breaker tripped · real-time notifications&lt;/span&gt;" vertex="1"><mxGeometry height="60" width="215" x="890" y="140" as="geometry" /></mxCell>
        <mxCell id="jira-out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="&lt;b&gt;Jira Integration&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;bug tickets (classification=bug) · severity HIGH · local DB + optional Jira API push · KAN project · atlassian-python-api&lt;/span&gt;" vertex="1"><mxGeometry height="60" width="215" x="1145" y="140" as="geometry" /></mxCell>
        <mxCell id="apscron" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="&lt;b&gt;APScheduler / Manual&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;nightly_run @ 02:00 UTC · index_rebuild every 12h · POST /pipeline/run&lt;/span&gt;" vertex="1"><mxGeometry height="60" width="235" x="1400" y="140" as="geometry" /></mxCell>
        <!-- ORCHESTRATOR ZONE -->
        <mxCell id="orch-zone" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#1E3A8A;dashed=0;strokeWidth=2;" value="" vertex="1"><mxGeometry height="190" width="900" x="640" y="290" as="geometry" /></mxCell>
        <mxCell id="orch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1E3A8A;fontStyle=1;fontSize=12;fontColor=#FFFFFF;" value="&lt;b style=&quot;font-size:16px;&quot;&gt;ORCHESTRATOR (orchestrator.py)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;FastAPI entry point · manages run lifecycle · emits SSE events · enforces HITL gates + circuit breakers · runs on Railway&lt;br&gt;Routes: POST /pipeline/run · GET /runs/{id}/stream (SSE) · POST /runs/{id}/approve&lt;/span&gt;" vertex="1"><mxGeometry height="80" width="860" x="660" y="305" as="geometry" /></mxCell>
        <mxCell id="orch-r1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B82F6;strokeColor=#1E3A8A;fontSize=10;fontColor=#FFFFFF;" value="&lt;b&gt;Plan&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;Check circuit breakers · select nodes to invoke · pause for HITL when conditions met (5 triggers)&lt;/span&gt;" vertex="1"><mxGeometry height="65" width="270" x="680" y="400" as="geometry" /></mxCell>
        <mxCell id="orch-r2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B82F6;strokeColor=#1E3A8A;fontSize=10;fontColor=#FFFFFF;" value="&lt;b&gt;Dispatch &amp;amp; track&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;Invoke nodes as async coroutines · emit SSE per node · update qa_runs status at each transition&lt;/span&gt;" vertex="1"><mxGeometry height="65" width="270" x="965" y="400" as="geometry" /></mxCell>
        <mxCell id="orch-r3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B82F6;strokeColor=#1E3A8A;fontSize=10;fontColor=#FFFFFF;" value="&lt;b&gt;Synthesise &amp;amp; close&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;Trigger Reporter node · emit run_complete SSE · write cost + pr_url to DB · fire Slack webhook&lt;/span&gt;" vertex="1"><mxGeometry height="65" width="270" x="1250" y="400" as="geometry" /></mxCell>
        <!-- Arrows: triggers → Orchestrator -->
        <mxCell id="e-pr-orch" edge="1" parent="1" source="gh-pr" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" target="orch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-cron-orch" edge="1" parent="1" source="apscron" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.8;entryY=0;" target="orch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Arrows: Orchestrator → outputs -->
        <mxCell id="e-orch-ui" edge="1" parent="1" source="orch" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.25;exitY=0;entryX=0.5;entryY=1;" target="agent-ui" value="&lt;span style=&quot;background:#FFF;font-size:9px;&quot;&gt;SSE stream&lt;/span&gt;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-orch-slack" edge="1" parent="1" source="orch" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.45;exitY=0;entryX=0.5;entryY=1;" target="slack-out" value="&lt;span style=&quot;background:#FFF;font-size:9px;&quot;&gt;webhook&lt;/span&gt;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-orch-jira" edge="1" parent="1" source="orch" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.58;exitY=0;entryX=0.5;entryY=1;" target="jira-out" value="&lt;span style=&quot;background:#FFF;font-size:9px;&quot;&gt;ticket&lt;/span&gt;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- SSE BUS -->
        <mxCell id="sse-bus" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#D6B656;fontSize=11;fontStyle=1;" value="&lt;b&gt;SSE Event Bus&lt;/b&gt; — FastAPI StreamingResponse · events: node_start → node_update → node_complete → hitl_required → run_complete · consumed by Agent UI (NodeGraph live-updates, no polling)" vertex="1"><mxGeometry height="50" width="1820" x="200" y="510" as="geometry" /></mxCell>
        <mxCell id="e-orch-bus" edge="1" parent="1" source="orch-zone" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="sse-bus"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- PIPELINE NODES ZONE -->
        <mxCell id="nodes-zone" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#15803D;dashed=1;verticalAlign=top;fontSize=11;fontStyle=1;" value="&lt;b&gt;Pipeline Nodes&lt;/b&gt; — internal, invoked sequentially by the Orchestrator · each node has one responsibility, own tool, own fallback, own metric · all zero-cost except Triage + Reporter" vertex="1"><mxGeometry height="340" width="1980" x="40" y="600" as="geometry" /></mxCell>
        <!-- NODE 1: Canary -->
        <mxCell id="n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;① Canary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;site health gate&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; demo site URL&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; async HTTP HEAD → 200 OK gate · abort + log system_event if fail&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; site_up=True → proceed · False → ABORTED&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; httpx · no LLM · zero cost&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; uptime detection · false abort rate&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="60" y="640" as="geometry" /></mxCell>
        <!-- NODE 2: Suite Selector -->
        <mxCell id="n2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;② Suite Selector&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;smart test scope&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; commit message + selector_index.json&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; regex keyword match first → 2-3 test files · if ambiguous (no keyword match) → Groq llama-3.3-70b interprets commit intent · last resort: run all suites&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; list of test files to run + rationale&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; deterministic Python + Groq API (ambiguous commits only)&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; coverage precision/recall vs affected pages&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="340" y="640" as="geometry" /></mxCell>
        <!-- NODE 3: Test Runner -->
        <mxCell id="n3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;③ Test Runner&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;execute tests against live site&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; suite list, GitHub Pages URL&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; subprocess pytest --junit-xml · Chromium headless · runs against lamaqrait.github.io/rait-qa-demo&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; JUnit XML (pass/fail per test)&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; pytest-playwright · Chromium · no LLM&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; run completion rate · execution time&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="620" y="640" as="geometry" /></mxCell>
        <!-- NODE 4: DOM Inspector -->
        <mxCell id="n4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;④ DOM Inspector&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;find selector candidates&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; failing test selectors, page URLs&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; Playwright crawl → snapshot DOM · fuzzy match each failed selector (difflib.SequenceMatcher)&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; candidate list with similarity scores 0–1&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; Playwright async API · Python difflib · no LLM&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; candidate recall vs actual new selector&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="900" y="640" as="geometry" /></mxCell>
        <!-- NODE 5: Triage -->
        <mxCell id="n5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor:#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;⑤ Triage (Intent-Aware)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;classify failures via LLM + intent comments&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; JUnit failures, DOM candidates, commit message, # INTENT: comments from test files&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; extract intent from test code · structured prompt → Groq llama-3.3-70b · intent context improves classification (e.g., URL change + intent='dashboard' → BUG not DRIFT) · if API fails → deterministic keyword fallback&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; classification (drift/bug/env/flaky) + confidence (0–1) + proposed_fix + intent_matched flag&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; Groq API · Langfuse trace · deterministic fallback · intent_parser.py&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; classification accuracy vs engineer ground-truth · intent match rate&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="1180" y="640" as="geometry" /></mxCell>
        <!-- NODE 6: Auto-Fixer -->
        <mxCell id="n6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;⑥ Auto-Fixer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;open self-healing PR&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; proposed_fix, test file path, run_id&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; only if drift + confidence ≥ 0.80 · patch test file · GitHub API: branch qa-agent/auto-heal → commit → open PR&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; GitHub PR URL stored in qa_runs&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; GitHub REST API (PAT) · no LLM&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; PR merge rate · regression rate post-merge&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="1460" y="640" as="geometry" /></mxCell>
        <!-- NODE 7: Reporter -->
        <mxCell id="n7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=10;align=left;verticalAlign=top;" value="&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;⑦ Reporter&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;generate incident summary&lt;/span&gt;&lt;/blockquote&gt;&lt;br&gt;&lt;blockquote style=&quot;margin: 0 0 0 10px; border: none; padding: 0px;&quot;&gt;&lt;b&gt;Inputs:&lt;/b&gt; run result (classification, confidence, pr_url, failures)&lt;br&gt;&lt;b&gt;Logic:&lt;/b&gt; summary prompt → Groq · fallback to template on API fail&lt;br&gt;&lt;b&gt;Output:&lt;/b&gt; report_text in qa_runs.report_text · shown in RunReportDrawer&lt;br&gt;&lt;b&gt;Tool:&lt;/b&gt; Groq API (llama-3.3-70b) · Langfuse trace&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; report generation success rate · avg tokens&lt;/blockquote&gt;" vertex="1"><mxGeometry height="270" width="255" x="1740" y="640" as="geometry" /></mxCell>
        <!-- Bus → node arrows -->
        <mxCell id="e-b1" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.08;exitY=1;entryX=0.5;entryY=0;" target="n1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-b2" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.22;exitY=1;entryX=0.5;entryY=0;" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-b3" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.37;exitY=1;entryX=0.5;entryY=0;" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-b4" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.52;exitY=1;entryX=0.5;entryY=0;" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-b5" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.67;exitY=1;entryX=0.5;entryY=0;" target="n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-b6" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.82;exitY=1;entryX=0.5;entryY=0;" target="n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-b7" edge="1" parent="1" source="sse-bus" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#D6B656;exitX=0.94;exitY=1;entryX=0.5;entryY=0;" target="n7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- SEQUENTIAL FLOW ARROWS -->
        <mxCell id="sq12" edge="1" parent="1" source="n1" target="n2" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#15803D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value=""><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sq23" edge="1" parent="1" source="n2" target="n3" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#15803D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value=""><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sq34" edge="1" parent="1" source="n3" target="n4" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#15803D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value=""><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sq45" edge="1" parent="1" source="n4" target="n5" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#15803D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value=""><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sq56" edge="1" parent="1" source="n5" target="n6" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#15803D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value=""><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sq67" edge="1" parent="1" source="n6" target="n7" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#15803D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" value=""><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- SHARED STATE ZONE -->
        <mxCell id="infra-zone" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F0F8FF;strokeColor=#2B6CB0;dashed=1;verticalAlign=top;fontSize=11;fontStyle=1;" value="&lt;b&gt;Shared State &amp;amp; Tools&lt;/b&gt; — every node reads/writes through these · this is where durability, audit, and cost tracking live" vertex="1"><mxGeometry height="330" width="1980" x="40" y="970" as="geometry" /></mxCell>
        <mxCell id="db-runs" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="&lt;b&gt;PostgreSQL — 5 tables&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;qa_runs (state machine) · users+teams (JWT RBAC) · tickets (Jira-style, severity) · notifications (in-app feed) · system_events (CB audit trail) · Railway managed&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="290" x="60" y="1010" as="geometry" /></mxCell>
        <mxCell id="cb-eng" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="&lt;b&gt;Circuit Breaker Engine&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;4 guards: cost &gt;$0.50/run · error rate &gt;20% · FPR &gt;15% · conf drop &gt;15pp/24h · trips abort run + escalate · POST /admin/reset-circuit-breakers&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="280" x="380" y="1010" as="geometry" /></mxCell>
        <mxCell id="apcell" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="&lt;b&gt;APScheduler&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;nightly_run @ 02:00 UTC · selector_index rebuild every 12h · SQLiteJobStore (persistent across restarts)&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="240" x="690" y="1010" as="geometry" /></mxCell>
        <mxCell id="langfuse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="&lt;b&gt;Langfuse (US Cloud)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;trace per LLM call · tokens_in / tokens_out / cost_usd · langfuse_trace_url stored in qa_runs · us.cloud.langfuse.com&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="240" x="960" y="1010" as="geometry" /></mxCell>
        <mxCell id="groq" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="&lt;b&gt;Groq Cloud&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;llama-3.3-70b-versatile · api.groq.com · ~200 tok/s · &lt;$0.001/run · used by Suite Selector (ambiguous commits), Triage + Reporter&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="240" x="1230" y="1010" as="geometry" /></mxCell>
        <mxCell id="ghapi" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" value="&lt;b&gt;GitHub API + Pages&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;Pages = live test target (10 demo pages) · PAT auth for PR creation · branch: qa-agent/auto-heal&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="240" x="1500" y="1010" as="geometry" /></mxCell>
        <mxCell id="jwt-rbac" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" value="&lt;b&gt;JWT Auth — 5 Roles&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;Super Admin · QA Manager (HITL approve) · QA Engineer (trigger runs) · Developer (read-only) · Viewer (dashboard only) · stateless Bearer tokens&lt;/span&gt;" vertex="1"><mxGeometry height="120" width="240" x="1770" y="1010" as="geometry" /></mxCell>
        <!-- RAILWAY + METRICS ROW -->
        <mxCell id="railway" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=10;align=left;verticalAlign=top;fontStyle=1;" value="&lt;b&gt;Railway — Production Deployment&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;agent-ui service:&lt;/b&gt; Next.js 15 · PORT=3000 · $NEXT_PUBLIC_API_URL · auto-deploy on push to main&lt;br&gt;&lt;b&gt;backend service:&lt;/b&gt; FastAPI + Uvicorn · PORT=8000 · env: $GROQ_API_KEY, $DATABASE_URL, $LANGFUSE_SECRET_KEY, $GITHUB_PAT, $JWT_SECRET&lt;br&gt;&lt;b&gt;PostgreSQL plugin:&lt;/b&gt; Railway managed · $DATABASE_URL auto-injected · persistent volumes · zero config&lt;br&gt;&lt;b&gt;Deploy flow:&lt;/b&gt; git push main → Railway CI → build → health check → traffic swap · rollback in 1 click&lt;/span&gt;" vertex="1"><mxGeometry height="110" width="940" x="60" y="1150" as="geometry" /></mxCell>
        <mxCell id="metrics" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=10;align=left;verticalAlign=top;fontStyle=1;" value="&lt;b&gt;Metrics &amp;amp; Observability&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;Per-run (qa_runs):&lt;/b&gt; pass_count, fail_count, cost_usd, duration_s, classification, confidence, langfuse_trace_url&lt;br&gt;&lt;b&gt;System (MetricsPanel — Agent UI):&lt;/b&gt; error_rate, FPR rate, avg_cost_per_run, CB trip count, classification accuracy (weekly sampled)&lt;br&gt;&lt;b&gt;LLM (Langfuse):&lt;/b&gt; tokens_in, tokens_out, cost_usd per call · trace URL stored in qa_runs · us.cloud.langfuse.com&lt;br&gt;&lt;b&gt;Scheduler:&lt;/b&gt; nightly pass trend · selector_index freshness · feeds CB confidence-drift guard&lt;/span&gt;" vertex="1"><mxGeometry height="110" width="970" x="1030" y="1150" as="geometry" /></mxCell>
        <!-- NOTES -->
        <mxCell id="notes" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F0F8FF;strokeColor=#2B6CB0;verticalAlign=top;fontSize=10;align=left;" value="&lt;b&gt;Why this shape&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;• &lt;b&gt;Orchestrator is the only entry point&lt;/b&gt;: consistent API surface, simple mental model — all callers hit POST /pipeline/run&lt;br&gt;• &lt;b&gt;Nodes are bounded&lt;/b&gt;: one responsibility each, own fallback strategy — swap Groq without touching Runner or Fixer&lt;br&gt;• &lt;b&gt;SSE bus decouples frontend&lt;/b&gt;: Agent UI renders live NodeGraph without blocking the pipeline or polling&lt;br&gt;• &lt;b&gt;PostgreSQL is durable state&lt;/b&gt;: pipeline is resumable; HITL pause can last indefinitely without losing run context&lt;br&gt;• &lt;b&gt;Cost is contained&lt;/b&gt;: LLM only in Triage + Reporter; 5 of 7 nodes are zero-cost deterministic code&lt;/span&gt;" vertex="1"><mxGeometry height="160" width="970" x="40" y="1320" as="geometry" /></mxCell>
        <mxCell id="rules" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFAF0;strokeColor=#B85450;verticalAlign=top;fontSize=10;align=left;" value="&lt;b&gt;Hard rules&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#B85450;&quot;&gt;✗ Auto-Fixer never merges PRs — only opens them; humans must review and merge&lt;br&gt;✗ No node reads or writes production data — only qa_runs, tickets, notifications tables&lt;br&gt;✗ Circuit breaker trips abort the ENTIRE run before the next node starts&lt;br&gt;✗ Triage prompt contains only test IDs, selectors, DOM text — never real user PII&lt;br&gt;✗ Nodes never call Groq directly — always via triage.py / reporter.py with budget checks&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#82B366;&quot;&gt;✓ Every node action recorded in qa_runs with timestamp and outcome&lt;br&gt;✓ LLM cost tracked per run in qa_runs.cost_usd + Langfuse trace URL&lt;br&gt;✓ HITL always wins — low confidence, new failure type, or high impact forces human approval&lt;/span&gt;" vertex="1"><mxGeometry height="160" width="1010" x="1030" y="1320" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Pipeline Sequence — Selector Drift" id="rait-qa-seq">
    <mxGraphModel dx="2400" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="title2" value="&lt;b style=&quot;font-size:20px;&quot;&gt;Pipeline Sequence — PR with selector drift&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#555;&quot;&gt;Time flows top to bottom · Orchestrator is the only component talking to humans (SSE stream + Slack) · pipeline nodes communicate results back to Orchestrator&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="2120" height="60" as="geometry" /></mxCell>
        <!-- LIFELINE HEADERS -->
        <mxCell id="lh-dev" value="&lt;b&gt;Developer&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-gh" value="&lt;b&gt;GitHub / Pages&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="210" y="100" width="140" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-orch" value="&lt;b&gt;Orchestrator&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1E3A8A;fontSize=11;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="390" y="100" width="140" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-canary" value="&lt;b&gt;Canary&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="100" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-suite" value="&lt;b&gt;Suite Selector&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="740" y="100" width="140" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-runner" value="&lt;b&gt;Test Runner&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;&quot;&gt;Playwright&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="920" y="100" width="140" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-dom" value="&lt;b&gt;DOM Inspector&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1100" y="100" width="140" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-triage" value="&lt;b&gt;Triage&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1280" y="100" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-fixer" value="&lt;b&gt;Auto-Fixer&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1450" y="100" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-rep" value="&lt;b&gt;Reporter&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1620" y="100" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-db" value="&lt;b&gt;PostgreSQL&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1790" y="100" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="lh-ui" value="&lt;b&gt;Agent UI&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1960" y="100" width="130" height="40" as="geometry" /></mxCell>
        <!-- LIFELINES -->
        <mxCell id="ll-dev" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="105" y="145" as="sourcePoint"/><mxPoint x="105" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-gh" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="145" as="sourcePoint"/><mxPoint x="280" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-orch" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#1E3A8A;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="145" as="sourcePoint"/><mxPoint x="460" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-can" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="635" y="145" as="sourcePoint"/><mxPoint x="635" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-sui" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="810" y="145" as="sourcePoint"/><mxPoint x="810" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-run" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="145" as="sourcePoint"/><mxPoint x="990" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-dom" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1170" y="145" as="sourcePoint"/><mxPoint x="1170" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-tri" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1345" y="145" as="sourcePoint"/><mxPoint x="1345" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-fix" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1515" y="145" as="sourcePoint"/><mxPoint x="1515" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-rep" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1685" y="145" as="sourcePoint"/><mxPoint x="1685" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-db" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1855" y="145" as="sourcePoint"/><mxPoint x="1855" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll-ui" style="endArrow=none;html=1;rounded=0;dashed=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="2025" y="145" as="sourcePoint"/><mxPoint x="2025" y="1280" as="targetPoint"/></mxGeometry></mxCell>
        <!-- MESSAGES -->
        <mxCell id="m1" value="1. git push (CSS class rename: btn-checkout → btn-place-order)" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="105" y="180" as="sourcePoint"/><mxPoint x="280" y="180" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m2" value="2. POST /pipeline/run {commit_sha, message}" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="220" as="sourcePoint"/><mxPoint x="460" y="220" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m3" value="3. INSERT qa_runs, status='running'" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#6C8EBF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="260" as="sourcePoint"/><mxPoint x="1855" y="260" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m4" value="4. SSE stream opened → Agent UI (run_id, status=running)" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=10;strokeColor=#1E3A8A;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="300" as="sourcePoint"/><mxPoint x="2025" y="300" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m5" value="5. canary_check(lamaqrait.github.io/rait-qa-demo)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="340" as="sourcePoint"/><mxPoint x="635" y="340" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m6" value="6. site_up=True → proceed" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="635" y="380" as="sourcePoint"/><mxPoint x="460" y="380" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m7" value="7. suite_select(commit='rename btn-checkout')" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="420" as="sourcePoint"/><mxPoint x="810" y="420" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m8" value="8. [test_checkout.py, test_cart.py]" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="810" y="460" as="sourcePoint"/><mxPoint x="460" y="460" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m9" value="9. run_tests(suites, target=GitHub Pages)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="500" as="sourcePoint"/><mxPoint x="990" y="500" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m10" value="10. Playwright GET pages, assert selectors" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="540" as="sourcePoint"/><mxPoint x="280" y="540" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m11" value="11. HTML (btn-place-order exists, btn-checkout absent)" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="580" as="sourcePoint"/><mxPoint x="990" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m12" value="12. 2 FAIL — AssertionError: btn-checkout not found" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="990" y="620" as="sourcePoint"/><mxPoint x="460" y="620" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m13" value="13. dom_inspect(failing=['btn-checkout'], page_url)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#9673A6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460" y="660" as="sourcePoint"/><mxPoint x="1170" y="660" as="targetPoint"/></mxGeometry></mxCell>
