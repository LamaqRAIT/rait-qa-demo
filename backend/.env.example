# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Primary LLM — get free key at https://aistudio.google.com
GOOGLE_API_KEY=your-gemini-api-key-here

# Fallback LLM — get free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Database (SQLite for local dev, PostgreSQL for Railway)
DATABASE_URL=sqlite+aiosqlite:///./demo.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db  # Railway production

# Demo site URL (GitHub Pages)
BASE_URL=https://lamaqrait.github.io/rait-qa-demo

# CORS — where the Agent UI runs during demo
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Optional: GitHub webhook HMAC secret (leave blank for local dev)
GITHUB_WEBHOOK_SECRET=
